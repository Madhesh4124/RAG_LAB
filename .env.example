# ============================================================================
# RAG Lab Environment Variables - Example Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit real secrets to version control
# ============================================================================

# ============================================================================
# STORAGE (HF Space Bucket mounted at /data)
# ============================================================================
DATABASE_URL=sqlite:////data/rag_lab.db
CHROMA_PERSIST_DIR=/data/chroma_data
UPLOAD_DIR=/data/uploads

# Local Postgres compose defaults (used by docker-compose.yml)
POSTGRES_DB=raglab
POSTGRES_USER=raglab
POSTGRES_PASSWORD=change-me

# ============================================================================
# LLM PROVIDER (Gemini)
# ============================================================================
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=AIza...your-google-api-key

# ============================================================================
# EMBEDDING PROVIDERS
# ============================================================================
DEFAULT_EMBEDDING_PROVIDER=nvidia
DEFAULT_EMBEDDING_MODEL=nvidia/nv-embed-v1
NVIDIA_API_KEY=nvapi-...your-nvidia-api-key
HUGGINGFACE_API_KEY=hf_...your-huggingface-token

# Optional local CLIP image indexing for embedded PDF images.
# First run downloads the Hugging Face model unless already cached.
PDF_IMAGE_INDEXING_ENABLED=false
HF_IMAGE_EMBEDDING_MODEL=openai/clip-vit-base-patch32
# Alternative higher-quality multimodal model (heavier):
# HF_IMAGE_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B
PDF_IMAGE_MIN_WIDTH=64
PDF_IMAGE_MIN_HEIGHT=64

# ============================================================================
# RATE LIMITING (Per-User, Per-Hour)
# ============================================================================
MAX_LLM_CALLS_PER_HOUR=15
MAX_EMBEDDING_CALLS_PER_HOUR=50
MAX_RETRIEVAL_CALLS_PER_HOUR=100

# ============================================================================
# TELEMETRY (Local Development)
# ============================================================================
ANONYMIZED_TELEMETRY=FALSE
