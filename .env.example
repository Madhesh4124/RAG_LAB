# ============================================================================
# RAG Lab Environment Variables - Example Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit real secrets to version control
# ============================================================================

# ============================================================================
# STORAGE (HF Space Bucket mounted at /data)
# ============================================================================
DATABASE_URL=sqlite:////data/rag_lab.db
CHROMA_PERSIST_DIR=/data/chroma_data
UPLOAD_DIR=/data/uploads

# ============================================================================
# LLM PROVIDER (Gemini)
# ============================================================================
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemma-4-26b-a4b-it
GOOGLE_API_KEY=AIza...your-google-api-key

# ============================================================================
# EMBEDDING PROVIDERS
# ============================================================================
DEFAULT_EMBEDDING_PROVIDER=nvidia
DEFAULT_EMBEDDING_MODEL=nvidia/nv-embed-v1
NVIDIA_API_KEY=nvapi-...your-nvidia-api-key
HUGGINGFACE_API_KEY=hf_...your-huggingface-token

# ============================================================================
# RATE LIMITING (Per-User, Per-Hour)
# ============================================================================
MAX_LLM_CALLS_PER_HOUR=15
MAX_EMBEDDING_CALLS_PER_HOUR=50
MAX_RETRIEVAL_CALLS_PER_HOUR=100

# ============================================================================
# TELEMETRY (Local Development)
# ============================================================================
ANONYMIZED_TELEMETRY=FALSE
