# Auth / session settings
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_SEED_USERNAME=admin
AUTH_SEED_EMAIL=admin@local
AUTH_SEED_PASSWORD=change-me

# Database
DATABASE_URL=sqlite:///./rag_lab.db

# Storage
CHROMA_PERSIST_DIR=./chroma_data
UPLOAD_DIR=./uploads

# Embedding API Keys
GOOGLE_API_KEY=your_google_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Default Embedding Config
DEFAULT_EMBEDDING_PROVIDER=nvidia
DEFAULT_EMBEDDING_MODEL=nvidia/nv-embed-v1

# LLM Config
GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemma-4-26b-a4b-it
